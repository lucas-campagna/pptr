{
  "name": "pptr",
  "version": "1.9.2",
  "description": "YAML-based Puppeteer automation script runner - standalone executable",
  "main": "src/index.js",
  "bin": {
    "pptr": "./src/cli.js"
  },
  "pkg": {
    "scripts": [
      "src/**/*.js"
    ],
    "assets": [
      "package.json"
    ],
    "outputPath": "dist",
    "targets": ["node18-linux-x64", "node18-macos-x64", "node18-win-x64"]
  },
  "scripts": {
    "start": "node src/cli.js",
    "test": "jest --runInBand",
    "build": "pkg . --targets node18-linux-x64 --out-path dist"
  },
  "type": "commonjs",
  "dependencies": {
    "pptr-core": "workspace:*",
    "commander": "^11.0.0",
    "js-yaml": "^4.1.1",
    "puppeteer": "^22.0.0",
    "expression-eval": "^2.0.1"
  },
  "devDependencies": {
    "pkg": "^5.8.1",
    "jest": "^29.6.1"
  }
}
